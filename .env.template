# ==============================================================================
# SKY-CLAW AGENT ECOSYSTEM - SECURE ENV TEMPLATE
# ==============================================================================
# ATENCIÓN: Este archivo es una plantilla. NUNCA hagas commit de tu archivo .env
# real. El archivo .env debe estar incluido en tu .gitignore.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. LLM Providers (Obligatorio para Agentes)
# ------------------------------------------------------------------------------
# Para AutoGPT, CrewAI, AutoGen y llamadas nativas.
OPENAI_API_KEY="sk-proj-..."
ANTHROPIC_API_KEY="sk-ant-..."
GEMINI_API_KEY="AIzaSy..."

# ------------------------------------------------------------------------------
# 2. MCP & Búsqueda (Contexto Externo)
# ------------------------------------------------------------------------------
# Requerido por el servidor MCP de Brave Search
BRAVE_API_KEY="tu_clave_de_brave_search_aqui"

# Alternativa: Tavily (Excelente para agentes autónomos)
TAVILY_API_KEY="tvly-..."

# ------------------------------------------------------------------------------
# 3. Integración GitHub (Gestión de Código)
# ------------------------------------------------------------------------------
# Token Clásico o Fine-grained con permisos de 'repo', 'workflow' y 'read:org'
GITHUB_TOKEN="ghp_..."

# ------------------------------------------------------------------------------
# 4. Configuración del Sandbox (Docker OpenHands / AutoGPT)
# ------------------------------------------------------------------------------
WORKSPACE_BASE="E:/Skyclaw_Main_Sync"
WORKSPACE_MOUNT_PATH="/workspace"
SANDBOX_USER_ID="1000"

# ------------------------------------------------------------------------------
# 5. Entorno Sky-Claw
# ------------------------------------------------------------------------------
ENVIRONMENT="development"
LOG_LEVEL="DEBUG"
# En caso de conectar el swarm-memory-manager a una DB externa
DATABASE_URL="sqlite:///./global_titan.db"
