{
  "$schema": "https://antigravity.dev/schema/settings/v2",
  "_comment": "Generated by SkyClaw - .git exclusion config for Antigravity IDE",
  "type": "object",
  "indexing": {
    "excludePatterns": [
      ".git/**",
      ".git/*",
      "**/.git/**",
      "**/.git/*"
    ],
    "maxFileSize": "4MB",
    "skipBinaryFiles": true,
    "skipHiddenDirectories": true
  },
  "agent": {
    "contextExclusions": [
      ".git",
      ".git/objects",
      ".git/refs",
      ".git/hooks",
      ".git/logs",
      ".git/info",
      ".git/modules"
    ],
    "fileWatcherExclusions": [
      ".git/**"
    ],
    "indexingDisabledPaths": [
      "E:\\Skyclaw_Main_Sync\\.git"
    ]
  },
  "performance": {
    "maxConcurrentIndexers": 2,
    "indexingTimeoutMs": 5000,
    "skipLargeDirectories": true,
    "largeDirectoryThreshold": 500
  }
}
