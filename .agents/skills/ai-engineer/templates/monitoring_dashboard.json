{
  "dashboard": {
    "title": "Sky-Claw AI System Monitoring",
    "version": "2026.03",
    "refresh_interval": "30s",
    "panels": [
      {
        "id": "overview",
        "title": "📊 Overview",
        "type": "stats",
        "metrics": [
          {
            "name": "Total Requests (24h)",
            "query": "sum(llm_requests_total)",
            "unit": "requests"
          },
          {
            "name": "Average Latency",
            "query": "avg(llm_request_latency_ms)",
            "unit": "ms"
          },
          {
            "name": "Error Rate",
            "query": "rate(llm_errors_total[5m]) / rate(llm_requests_total[5m])",
            "unit": "percent"
          },
          {
            "name": "Cost (24h)",
            "query": "sum(llm_cost_usd_total)",
            "unit": "USD"
          }
        ]
      },
      {
        "id": "latency",
        "title": "⏱️ Latencia por Endpoint",
        "type": "timeseries",
        "queries": [
          {
            "name": "p50",
            "query": "histogram_quantile(0.50, llm_request_latency_ms_bucket)"
          },
          {
            "name": "p95",
            "query": "histogram_quantile(0.95, llm_request_latency_ms_bucket)"
          },
          {
            "name": "p99",
            "query": "histogram_quantile(0.99, llm_request_latency_ms_bucket)"
          }
        ],
        "thresholds": [
          {"value": 2000, "severity": "warning"},
          {"value": 5000, "severity": "critical"}
        ]
      },
      {
        "id": "cost",
        "title": "💰 Costo por Modelo",
        "type": "piechart",
        "query": "sum by (model) (llm_cost_usd_total)",
        "legend": true
      },
      {
        "id": "throughput",
        "title": "📈 Throughput",
        "type": "timeseries",
        "queries": [
          {
            "name": "Requests/sec",
            "query": "rate(llm_requests_total[1m])"
          },
          {
            "name": "Tokens/sec",
            "query": "rate(llm_tokens_total[1m])"
          }
        ]
      },
      {
        "id": "errors",
        "title": "❌ Errores por Tipo",
        "type": "barchart",
        "query": "sum by (error_type) (llm_errors_total)",
        "grouping": "error_type"
      },
      {
        "id": "cache",
        "title": "🚀 Cache Performance",
        "type": "gauge",
        "metrics": [
          {
            "name": "Hit Rate",
            "query": "rate(cache_hits_total[5m]) / (rate(cache_hits_total[5m]) + rate(cache_misses_total[5m]))",
            "unit": "percent",
            "thresholds": [
              {"value": 0.4, "severity": "warning"},
              {"value": 0.6, "severity": "good"}
            ]
          }
        ]
      },
      {
        "id": "rag",
        "title": "🔍 RAG Metrics",
        "type": "timeseries",
        "queries": [
          {
            "name": "Retrieval Latency",
            "query": "avg(rag_retrieval_latency_ms)"
          },
          {
            "name": "Documents Retrieved",
            "query": "avg(rag_documents_retrieved)"
          },
          {
            "name": "Relevance Score",
            "query": "avg(rag_avg_relevance_score)"
          }
        ]
      },
      {
        "id": "budget",
        "title": "💵 Budget Tracking",
        "type": "gauge",
        "metrics": [
          {
            "name": "Daily Budget Used",
            "query": "sum(llm_cost_usd_total) / 50.0 * 100",
            "unit": "percent",
            "thresholds": [
              {"value": 80, "severity": "warning"},
              {"value": 100, "severity": "critical"}
            ]
          }
        ]
      },
      {
        "id": "models",
        "title": "🤖 Usage por Modelo",
        "type": "table",
        "columns": [
          {"name": "Model", "field": "model"},
          {"name": "Requests", "field": "requests", "format": "number"},
          {"name": "Tokens", "field": "tokens", "format": "number"},
          {"name": "Cost", "field": "cost", "format": "currency"},
          {"name": "Avg Latency", "field": "latency", "format": "ms"},
          {"name": "Error Rate", "field": "error_rate", "format": "percent"}
        ],
        "query": "sum by (model) (llm_requests_total, llm_tokens_total, llm_cost_usd_total, llm_errors_total)"
      },
      {
        "id": "alerts",
        "title": "🚨 Active Alerts",
        "type": "alertlist",
        "query": "alerts{state='firing'}",
        "show_silenced": false
      }
    ],
    "alerts": [
      {
        "name": "High Error Rate",
        "condition": "rate(llm_errors_total[5m]) / rate(llm_requests_total[5m]) > 0.05",
        "duration": "5m",
        "severity": "critical",
        "channels": ["telegram", "email"]
      },
      {
        "name": "Budget Exceeded",
        "condition": "sum(llm_cost_usd_total) > 50.0",
        "duration": "1m",
        "severity": "critical",
        "channels": ["telegram"]
      },
      {
        "name": "High Latency",
        "condition": "histogram_quantile(0.95, llm_request_latency_ms_bucket) > 5000",
        "duration": "10m",
        "severity": "warning",
        "channels": ["telegram"]
      },
      {
        "name": "Cache Hit Rate Low",
        "condition": "rate(cache_hits_total[5m]) / (rate(cache_hits_total[5m]) + rate(cache_misses_total[5m])) < 0.3",
        "duration": "30m",
        "severity": "warning",
        "channels": ["email"]
      }
    ]
  }
}
