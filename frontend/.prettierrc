{
    "$schema": "https://json.schemastore.org/prettierrc",
    "semi": true,
    "singleQuote": false,
    "quoteProps": "consistent",
    "trailingComma": "es5",
    "bracketSpacing": true,
    "bracketSameLine": false,
    "arrowParens": "always",
    "endOfLine": "auto",
    "tabWidth": 4,
    "useTabs": false,
    "printWidth": 120,
    "htmlWhitespaceSensitivity": "css",
    "vueIndentScriptAndStyle": false,
    "embeddedLanguageFormatting": "auto",
    "overrides": [
        {
            "files": ["*.html"],
            "options": {
                "printWidth": 120,
                "tabWidth": 4,
                "singleQuote": false
            }
        },
        {
            "files": ["*.css", "*.scss"],
            "options": {
                "printWidth": 100,
                "tabWidth": 4,
                "singleQuote": false
            }
        },
        {
            "files": ["*.js", "*.mjs", "*.cjs"],
            "options": {
                "printWidth": 120,
                "tabWidth": 4,
                "singleQuote": false
            }
        },
        {
            "files": ["*.json"],
            "options": {
                "printWidth": 100,
                "tabWidth": 4
            }
        }
    ]
}
